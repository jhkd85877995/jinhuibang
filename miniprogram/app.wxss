/* app.wxss - 全局样式 */

/* 使用 PingFang SC 字体（符合设计规格） */
page {
  font-family: 'PingFang SC', 'SF Pro Text', -apple-system, sans-serif;
  background-color: #F9FAFB;
  color: #111827;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 主色变量 */
/* 由于小程序不支持 CSS 变量，使用 class 定义 */
.text-primary {
  color: #1E3A8A;
}

.text-secondary {
  color: #3B82F6;
}

.text-accent {
  color: #F59E0B;
}

.text-gray {
  color: #6B7280;
}

.bg-primary {
  background-color: #1E3A8A;
}

.bg-secondary {
  background-color: #3B82F6;
}

.bg-accent {
  background-color: #F59E0B;
}

.bg-light {
  background-color: #F9FAFB;
}

/* 通用布局 */
.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 按钮样式 */
.btn-primary {
  background-color: #1E3A8A;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background-color: #3B82F6;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  border: none;
}

/* 数据卡片 */
.stat-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.stat-number {
  font-size: 56rpx;
  font-weight: bold;
  color: #1E3A8A;
  font-family: 'SF Pro Display', 'PingFang SC', sans-serif;
}

.stat-label {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 8rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #E5E7EB;
  margin: 24rpx 0;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #E5E7EB;
}

.list-item:last-child {
  border-bottom: none;
}

/* 导航栏样式覆盖 */
/* 小程序会自动使用 app.json 中配置的 navigationBar 颜色 */
