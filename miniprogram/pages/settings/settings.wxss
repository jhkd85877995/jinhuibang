.page { padding: 24rpx; background: #F9FAFB; min-height: 100vh; }
.header { margin-bottom: 32rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #111827; }
.user-card { display: flex; align-items: center; background: #fff; padding: 32rpx; border-radius: 16rpx; margin-bottom: 32rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; background: #1E3A8A; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 40rpx; margin-right: 24rpx; }
.user-info { flex: 1; }
.username { display: block; font-size: 32rpx; font-weight: bold; color: #111827; margin-bottom: 8rpx; }
.role { display: block; font-size: 24rpx; color: #6B7280; }
.menu-list { background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.menu-item { padding: 32rpx; border-bottom: 1rpx solid #E5E7EB; font-size: 28rpx; color: #111827; }
.menu-item:last-child { border-bottom: none; }
