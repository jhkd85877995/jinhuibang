.page { padding: 24rpx; background: #F9FAFB; min-height: 100vh; }
.header { margin-bottom: 32rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #111827; }
.stat-card { background: #fff; padding: 32rpx; border-radius: 16rpx; margin-bottom: 32rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.label { display: block; font-size: 24rpx; color: #6B7280; margin-bottom: 16rpx; }
.amount { display: block; font-size: 56rpx; font-weight: bold; color: #F59E0B; }
.section-title { font-size: 32rpx; font-weight: bold; color: #111827; margin: 32rpx 0; }
.empty-state { text-align: center; padding: 120rpx 0; }
.empty-text { font-size: 28rpx; color: #6B7280; }
