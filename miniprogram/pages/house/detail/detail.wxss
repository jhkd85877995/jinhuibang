/* pages/house/detail/detail.wxss - 房源详情样式 */
.page {
  background: #F9FAFB;
  min-height: 100vh;
  padding-bottom: 160rpx; /* 为操作按钮留空间 */
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  height: 500rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.no-image {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E5E7EB;
  color: #9CA3AF;
  font-size: 28rpx;
}

/* 信息区段 */
.info-section {
  background: #ffffff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #1E3A8A;
}

/* 价格行 */
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.price {
  font-size: 48rpx;
  font-weight: bold;
  color: #F59E0B;
  font-family: 'SF Pro Display', 'PingFang SC', sans-serif;
}

.status {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-vacant {
  background: #D1FAE5;
  color: #065F46;
}

.status-rented {
  background: #DBEAFE;
  color: #1E3A8A;
}

.status-review {
  background: #FEF3C7;
  color: #92400E;
}

/* 标题和地址 */
.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.address {
  display: block;
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.room-type {
  display: block;
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1E3A8A;
}

/* 描述 */
.description {
  display: block;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
}

/* 时间信息 */
.time-section {
  background: #F3F4F6;
  box-shadow: none;
}

.time-text {
  display: block;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
}

.time-text:last-child {
  margin-bottom: 0;
}

/* 操作按钮 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.06);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.edit-btn {
  flex: 1;
  background: #1E3A8A;
  color: #ffffff;
  padding: 28rpx 0;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.edit-btn::after {
  border: none;
}

.delete-btn {
  flex: 1;
  background: #DC2626;
  color: #ffffff;
  padding: 28rpx 0;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

.delete-btn::after {
  border: none;
}
