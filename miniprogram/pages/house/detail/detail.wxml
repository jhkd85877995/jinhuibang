<!--pages/house/detail/detail.wxml - 房源详情-->
<view class="page">
  <!-- 图片轮播 -->
  <swiper class="image-swiper" indicator-dots="{{images.length > 1}}" autoplay circular>
    <swiper-item wx:for="{{images}}" wx:key="index">
      <image src="{{item}}" mode="aspectFill" class="swiper-image" bindtap="previewImage" data-src="{{item}}"/>
    </swiper-item>
    <swiper-item wx:if="{{images.length === 0}}">
      <view class="no-image">暂无图片</view>
    </swiper-item>
  </swiper>

  <!-- 房源基本信息 -->
  <view class="info-section">
    <view class="price-row">
      <text class="price">¥{{house.price}}/月</text>
      <text class="status {{house.statusClass}}">{{house.statusText}}</text>
    </view>
    <text class="title">{{house.title}}</text>
    <text class="address">📍 {{house.address}}</text>
    <text class="room-type">🏠 {{house.roomType}}</text>
  </view>

  <!-- 租赁信息 -->
  <view class="info-section">
    <text class="section-title">租赁信息</text>
    <view class="info-grid">
      <view class="info-item">
        <text class="info-label">月租金</text>
        <text class="info-value">¥{{house.price}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">押金</text>
        <text class="info-value">¥{{house.deposit || '面议'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">浏览量</text>
        <text class="info-value">{{house.viewCount || 0}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">收藏数</text>
        <text class="info-value">{{house.likeCount || 0}}</text>
      </view>
    </view>
  </view>

  <!-- 房源描述 -->
  <view class="info-section" wx:if="{{house.description}}">
    <text class="section-title">房源描述</text>
    <text class="description">{{house.description}}</text>
  </view>

  <!-- 时间信息 -->
  <view class="info-section time-section">
    <text class="time-text">创建时间：{{house.createTimeStr}}</text>
    <text class="time-text">更新时间：{{house.updateTimeStr}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="edit-btn" bindtap="editHouse">编辑</button>
    <button class="delete-btn" bindtap="deleteHouse">删除</button>
  </view>
</view>
