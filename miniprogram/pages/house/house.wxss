/* pages/house/house.wxss - 房源管理样式 */
.page {
  padding: 24rpx;
  background-color: #F9FAFB;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #111827;
}

.add-btn {
  display: flex;
  align-items: center;
  background: #1E3A8A;
  color: #ffffff;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.add-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 24rpx;
}

.search-input {
  background: #ffffff;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tab {
  padding: 16rpx 32rpx;
  background: #ffffff;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #6B7280;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.06);
}

.tab.active {
  background: #1E3A8A;
  color: #ffffff;
}

/* 房源列表 */
.house-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.house-card {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.house-image {
  width: 240rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.house-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.house-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 12rpx;
}

.house-address {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.house-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.house-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #F59E0B;
}

.house-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-vacant {
  background: #D1FAE5;
  color: #065F46;
}

.status-rented {
  background: #DBEAFE;
  color: #1E3A8A;
}

.status-review {
  background: #FEF3C7;
  color: #92400E;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6B7280;
}
